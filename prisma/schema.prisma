generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id          BigInt       @id @default(autoincrement())
  email       String       @unique
  password    String
  name        String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  accessCodes AccessCode[]

  @@index([email])
}

model AccessCode {
  id          BigInt   @id @default(autoincrement())
  code        String   @unique @db.Char(4)
  usageCount  Int      @default(0)
  maxUsage    Int      @default(2)
  isActive    Boolean  @default(true)
  createdById BigInt?
  createdBy   User?    @relation(fields: [createdById], references: [id], onDelete: SetNull)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([code, isActive])
  @@index([createdById])
}

enum PaymentStatus {
  PENDING
  PAYMENT_DETECTED
}

model Payment {
  id              BigInt        @id @default(autoincrement())
  amount          Int
  status          PaymentStatus @default(PENDING)
  rawNotification Json?
  detectedAt      DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([status, amount])
}

model QrisNotification {
  id         BigInt   @id @default(autoincrement())
  signature  String   @unique @db.VarChar(255)
  amount     Int
  receivedAt BigInt
  rawPayload Json
  createdAt  DateTime @default(now())

  @@index([amount, receivedAt])
}
